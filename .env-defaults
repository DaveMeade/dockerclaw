OPENCLAW_GATEWAY_TOKEN=64-character-long-random-string-here
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_ALLOWED_ORIGINS='["http://127.0.0.1:18789","http://localhost:18789"]'
OPENCLAW_PROVIDER_ID=custom-host-docker-internal-11434
OPENCLAW_PROVIDER_MODEL=gpt-oss:20b
OPENCLAW_MODEL_ALIASES='ollama_gpt-oss:20b'
OPENCLAW_CONTEXT_WINDOW=16000
OPENCLAW_MAX_TOKENS=16000

# satisfy upstream mounts using named volumes (NOT host paths)
OPENCLAW_CONFIG_DIR=/DO_NOT_USE
OPENCLAW_WORKSPACE_DIR=/DO_NOT_USE

# silence Claude vars (unused)
CLAUDE_AI_SESSION_KEY=disabled
CLAUDE_WEB_SESSION_KEY=disabled
CLAUDE_WEB_COOKIE=disabled
